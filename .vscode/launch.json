{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: FastAPI - Portfolio Organizer",
            "type": "python",
            "request": "launch",
            "module": "apps.portfolio_organizer.run_api",
            "args": [
                "--mode",
                "dev",
                "--host",
                "0.0.0.0",
                "--port",
                "8004",
                "--reload"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${workspaceFolder}/apps:${workspaceFolder}/agents",
                "LOG_LEVEL": "DEBUG"
            }
        },
        {
            "name": "Python: FastAPI - Decision Engine",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "apps.decision_engine.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8001",
                "--reload"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${workspaceFolder}/apps:${workspaceFolder}/agents"
            }
        },
        {
            "name": "Python: FastAPI - Auth Service",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "apps.auth_service.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8100",
                "--reload"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${workspaceFolder}/apps:${workspaceFolder}/agents",
                "LOG_LEVEL": "DEBUG"
            }
        },
        {
            "name": "Python: Agents - Cognitive Orchestrator",
            "type": "python",
            "request": "launch",
            "module": "agents.cognitive_agent.orchestrator",
            "args": [
                "--workflow",
                "analyze_gaps"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${workspaceFolder}/apps:${workspaceFolder}/agents"
            }
        },
        {
            "name": "Python: Streamlit - IT Compass",
            "type": "python",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "apps/it_compass/main.py",
                "--server.port",
                "8501"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${workspaceFolder}/apps:${workspaceFolder}/agents"
            }
        },
        {
            "name": "Python: FastAPI - MCP Server",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "apps.mcp_server.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8005",
                "--reload"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${workspaceFolder}/apps:${workspaceFolder}/agents"
            }
        },
        {
            "name": "Python: FastAPI - ML Model Registry",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "apps.ml_model_registry.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8002",
                "--reload"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${workspaceFolder}/apps:${workspaceFolder}/agents"
            }
        }
    ],
    "compounds": [
        {
            "name": "🚀 Core Microservices (Decision + Auth + MCP + ML)",
            "configurations": [
                "Python: FastAPI - Decision Engine",
                "Python: FastAPI - Auth Service",
                "Python: FastAPI - MCP Server",
                "Python: FastAPI - ML Model Registry"
            ],
            "stopAll": true
        },
        {
            "name": "🧠 Agents & Logic (Portfolio + Cognitive)",
            "configurations": [
                "Python: FastAPI - Portfolio Organizer",
                "Python: Agents - Cognitive Orchestrator"
            ],
            "stopAll": true
        },
        {
            "name": "🎨 UI Layer (IT Compass)",
            "configurations": [
                "Python: Streamlit - IT Compass"
            ],
            "stopAll": true
        }
    ]
}
