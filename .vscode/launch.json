{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Текущий файл",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: pytest текущий файл",
            "type": "python",
            "request": "launch",
            "module": "pytest",
            "args": ["${file}"],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: pytest весь проект",
            "type": "python",
            "request": "launch",
            "module": "pytest",
            "args": [
                "apps",
                "src",
                "--cov=apps",
                "--cov=src",
                "--cov-report=term-missing"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: FastAPI - Decision Engine",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "apps.decision_engine.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8001",
                "--reload"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: FastAPI - ML Model Registry",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "apps.ml_model_registry.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8002",
                "--reload"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Flask - Portfolio Organizer",
            "type": "python",
            "request": "launch",
            "module": "flask",
            "env": {
                "FLASK_APP": "apps/portfolio_organizer/src/app.py",
                "FLASK_DEBUG": "1",
                "SECRET_KEY": "dev-secret-key"
            },
            "args": [
                "run",
                "--host",
                "0.0.0.0",
                "--port",
                "8004",
                "--reload"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Auth Service",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "apps.auth_service.main:app",
                "--host",
                "0.0.0.0",
                "--port",
                "8100",
                "--reload"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Streamlit - IT Compass",
            "type": "python",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "apps/it_compass/app.py",
                "--server.port",
                "8501"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Koda CLI",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "koda",
            "console": "integratedTerminal"
        }
    ]
}
