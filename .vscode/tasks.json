{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 Запустить все сервисы",
      "type": "shell",
      "command": "docker-compose up -d",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "⏹️ Остановить все сервисы",
      "type": "shell",
      "command": "docker-compose down",
      "problemMatcher": []
    },
    {
      "label": "🧪 Запустить тесты",
      "type": "shell",
      "command": "make test",
      "group": "test",
      "problemMatcher": [
        "$python"
      ]
    },
    {
      "label": "🧪 Запустить тесты с покрытием",
      "type": "shell",
      "command": "pytest --cov=apps --cov=src --cov-report=html --cov-report=term-missing",
      "problemMatcher": [
        "$python"
      ]
    },
    {
      "label": "🔒 Аудит безопасности (Trivy)",
      "type": "shell",
      "command": "trivy fs .",
      "problemMatcher": []
    },
    {
      "label": "🐍 Аудит безопасности (Bandit)",
      "type": "shell",
      "command": "bandit -r src apps",
      "problemMatcher": []
    },
    {
      "label": "🎨 Форматировать код (Ruff)",
      "type": "shell",
      "command": "ruff format .",
      "problemMatcher": []
    },
    {
      "label": "🔍 Линтер Ruff (с автоисправлением)",
      "type": "shell",
      "command": "ruff check . --fix",
      "problemMatcher": [
        "$python"
      ]
    },
    {
      "label": "📊 Проверка типов (Pyright)",
      "type": "shell",
      "command": "pyright",
      "problemMatcher": [
        "$python"
      ]
    },
    {
      "label": "🔍 Pre-commit проверка",
      "type": "shell",
      "command": "pre-commit run --all-files",
      "problemMatcher": []
    },
    {
      "label": "🔄 Git Status",
      "type": "shell",
      "command": "git status",
      "problemMatcher": []
    },
    {
      "label": "🔄 Git Pull",
      "type": "shell",
      "command": "git pull origin main",
      "problemMatcher": []
    },
    {
      "label": "📤 Git Push",
      "type": "shell",
      "command": "git push origin main",
      "problemMatcher": []
    },
    {
      "label": "🏗️ Сборка Docker образов",
      "type": "shell",
      "command": "docker-compose build",
      "problemMatcher": []
    },
    {
      "label": "🧹 Очистка кэша Python",
      "type": "shell",
      "command": "find . -type d -name \"__pycache__\" -exec rm -rf {} + 2>/dev/null || Get-ChildItem -Recurse -Filter \"__pycache__\" | Remove-Item -Recurse -Force",
      "problemMatcher": []
    },
    {
      "label": "📝 Генерация документации",
      "type": "shell",
      "command": "mkdocs build",
      "problemMatcher": []
    },
    {
      "label": "🔍 Проверка секретов в Git",
      "type": "shell",
      "command": "gitleaks detect --no-git",
