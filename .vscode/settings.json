{
  // ===  ИИ-ассистенты (приоритет Koda, отключение конфликтов) ===
  "editor.inlineSuggest.enabled": true,
  "editor.suggestOnTriggerCharacters": true,
  "editor.tabCompletion": "on",
  
  // Koda: включаем как основной источник подсказок
  "koda.inlineCompletion.enabled": true,
  "koda.chat.enabled": true,
  
  // GigaCode: отключаем фоновую генерацию (причина лагов 20 мин)
  "gigacode.inlineSuggestion.enabled": false,
  "gigacode.indexing.enabled": false,
  "gigacode.enableChat": true, // Оставляем только чат по запросу
  
  // Отключаем остальные AI, чтобы не было борьбы за `Tab`
  "github.copilot.enable": { "*": false },
  "continue.enableTabAutocomplete": false,

  // === 🐍 Python & Монорепозиторий ===
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
  "python.analysis.extraPaths": [
    "./apps",
    "./src",
    "./tests",
    "./tools"
  ],
  "python.analysis.autoImportCompletions": true,
  "python.linting.enabled": true,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "ms-python.black-formatter",
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["tests/", "--cov=apps", "--cov=src"],

  // === 💻 Терминал (PowerShell, чистый запуск) ===
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell",
      "args": ["-ExecutionPolicy", "Bypass", "-NoLogo", "-NoProfile"]
    }
  },
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.copyOnSelection": true,

  // === ⚡ Производительность (критично для монорепы) ===
  "files.exclude": {
    "**/.git": true,
    "**/.venv": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/node_modules": true,
    "**/.pytest_cache": true
  },
  "search.exclude": {
    "**/.git": true,
    "**/.venv": true,
    "**/__pycache__": true,
    "**/node_modules": true,
    "**/.reports": true,
    "**/legacy": true
  },
  "search.followSymlinks": false,
  "workbench.startupEditor": "none",
  "editor.minimap.enabled": false,
  "workbench.editor.enablePreview": false,
  "workbench.editor.closeOnFileDelete": true,

  // === 🔗 Git & Рабочий процесс ===
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.openRepositoryInParentFolders": "never",
  "editor.wordWrap": "on",
  "editor.rulers": [88, 120],
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000
}