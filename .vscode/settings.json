{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
  "python.envFile": "${workspaceFolder}/.env",
  "python.terminal.useEnvFile": true,
  "python.terminal.activateEnvironment": true,
  "python.analysis.extraPaths": [
    "./apps",
    "./src",
    "./tests",
    "./tools"
  ],
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.variableTypes": true,
  "python.analysis.indexing": true,
  "python.analysis.packageIndexDepths": [
    { "name": "fastapi", "depth": 3, "includeAllSymbols": true },
    { "name": "pydantic", "depth": 3, "includeAllSymbols": true },
    { "name": "sqlalchemy", "depth": 2, "includeAllSymbols": true },
    { "name": "langchain", "depth": 2, "includeAllSymbols": true }
  ],
  "python.analysis.exclude": [
    "**/.venv",
    "**/__pycache__",
    "**/node_modules",
    "**/legacy",
    "**/.pytest_cache",
    "**/.mypy_cache",
    "**/.hypothesis"
  ],
  "python.linting.enabled": true,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "ms-python.black-formatter",
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": [
    "tests/",
    "--cov=apps",
    "--cov=src",
    "--cov-report=term-missing:skip-covered",
    "--no-cov-on-fail"
  ],
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell"
    }
  },
  "terminal.integrated.shellIntegration.enabled": true,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.env.windows": {
    "PYTHONPATH": "${workspaceFolder};${workspaceFolder}/apps;${workspaceFolder}/src"
  },
  "files.exclude": {
    "**/.git": true,
    "**/.venv": true,
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/node_modules": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.hypothesis": true,
    "**/.coverage": true,
    "**/htmlcov": true,
    "**/*.egg-info": true,
    "**/.tox": true,
    "**/dist": true,
    "**/build": true
  },
  "search.exclude": {
    "**/.git": true,
    "**/.venv": true,
    "**/__pycache__": true,
    "**/node_modules": true,
    "**/.reports": true,
    "**/legacy": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.hypothesis": true,
    "**/.coverage": true,
    "**/htmlcov": true,
    "**/*.egg-info": true,
    "**/.tox": true
  },
  "search.followSymlinks": false,
  "workbench.startupEditor": "none",
  "editor.minimap.enabled": false,
  "workbench.editor.enablePreview": false,
  "workbench.editor.closeOnFileDelete": true,
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.openRepositoryInParentFolders": "never",
  "git.branchProtection": ["main", "master", "production"],
  "editor.wordWrap": "on",
  "editor.rulers": [88, 120, 160],
  "editor.stickyScroll.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.indentation": true,
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.tabSize": 2
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.tabSize": 2
  },
  "gigacode.maxContextTokens": 2048,
  "gigacode.enableWorkspaceContext": false,
  "gigacode.agent.mode": "lightweight",
