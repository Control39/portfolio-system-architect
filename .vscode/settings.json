{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
  "python.terminal.activateEnvironment": true,
  "python.terminal.useEnvFile": true,
  "python.analysis.extraPaths": [
    "${workspaceFolder}/apps",
    "${workspaceFolder}/src"
  ],
  "python.analysis.diagnosticMode": "workspace",
  // ================================
  // GigaCode - ПРИОРИТЕТ (основной инструмент)
  // ================================
  "gigacode.enabled": true,
  "gigacode.apiKey": "${env:GIGACODE_API_KEY}",
  "gigacode.model": "GigaChat",
  "gigacode.maxTokens": 4000,
  "gigacode.temperature": 0.7,
  "gigacode.contextWindow": 8000,
  "gigacode.language": "ru",
  "gigacode.enableCodeCompletion": true,
  "gigacode.enableChat": true,
  "gigacode.autoSuggest": true,
  "gigacode.suggestDelay": 500, // 💰 Чуть увеличил задержку: меньше ложных срабатываний = экономия токенов
  "gigacode.useWorkerForCommands": false,
  "gigacode.experimental.workerEnabled": false,
  "gigacode.inlineCompletions.enabled": true,
  "gigacode.chat.agentModel": "CodeChat",
  "gigacode.chat.askModel": "CodeChat",
  "gigacode.python.enabled": true,
  "gigacode.typescript.enabled": true,
  "gigacode.javascript.enabled": true,
  "gigacode.yaml.enabled": true,
  "gigacode.markdown.enabled": true,
  "gigacode.integrateWithCopilot": false,
  "gigacode.fallbackToSourceCraft": false, // 💰 ОТКЛЮЧЕНО: не тратить кредиты, если GigaCode не ответил
  "gigacode.showTokenUsage": true,
  "gigacode.notifyOnLowTokens": true,
  "gigacode.lowTokenThreshold": 50,
  "gigacode.cache_responses": true,
  // ================================
  // SourceCraft - РЕЖЕМ ФОН (только по запросу)
  // ================================
  "sourcecraft-code-assist.account": "leadarchitect@yandex.ru",
  // 💰 Отключаем авто-комплиты и фоновый анализ, чтобы не жег кредиты
  "sourcecraft-code-assist.enableAutoCompletion": false,
  "sourcecraft-code-assist.enableBackgroundAnalysis": false,
  // Оставляем safe-команды, но запуск только вручную
  "sourcecraft-code-assist.allowedCommands": [
    "git log",
    "git diff",
    "git show",
    "git status",
    "git branch",
    "git pull",
    "pip list",
    "python --version",
    "pytest --collect-only"
  ],
  "sourcecraft-code-assist.deniedCommands": [
    "rm -rf",
    "sudo",
    "shutdown",
    "reboot",
    "dd",
    "mkfs",
    "chmod 777",
    "git push --force",
    "npm install",
    "pip install" // 💰 Блокируем установку пакетов через ИИ для безопасности
  ],
  "sourcecraft-code-assist.useWorker": false,
  "sourcecraft-code-assist.runInTerminal": true,
  // 💰 Явный запрет на авто-запросы
  "sourcecraft-code-assist.autoTrigger": false,
  // ================================
  // Python - локальное форматирование (БЕСПЛАТНО ✅)
  // ================================
  "python.formatting.provider": "black",
  "python.linting.ruffEnabled": true,
  "python.linting.ruffArgs": [
    "--fix"
  ],
  // ================================
  // Редактор - автоформатирование (локальное)
  // ================================
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.trimAutoWhitespace": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "[python]": {
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    },
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "[json]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[yaml]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[powershell]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "ms-vscode.powershell"
  },
  "[typescript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[javascript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[markdown]": {
    "editor.formatOnSave": false
  },
  // ================================
  // Файлы - исключения (без изменений)
  // ================================
  "files.exclude": {
    "**/.git": true,
    "**/__pycache__": true,
    "**/.venv": true,
    "**/venv": true,
    "**/.pytest_cache": true,
    "**/.cache": true,
    "**/cache": true,
    "**/logs": true,
    "**/*.pyc": true,
    "**/*.pyo": true,
    "**/*.pyd": true,
    "**/.DS_Store": true,
    "**/*.exe": true,
    "**/*.dll": true,
    "**/*.so": true,
    "**/.env": true,
    "**/.env.*": true,
    "**/*.local": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.venv/**": true,
    "**/venv/**": true,
    "**/__pycache__/**": true
  },
  // ================================
  // Тестирование - pytest
  // ================================
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [
    "-p",
    "no:warnings",
    "--tb=short",
    "--cov=.",
    "${workspaceFolder}/tests"
  ],
  // ================================
  // Прочие настройки
  // ================================
  "editor.rulers": [
    80,
    100,
    120
  ],
  "editor.renderWhitespace": "selection",
  "editor.minimap.enabled": true,
  "workbench.editor.enablePreview": false,
  "explorer.confirmDragAndDrop": false,
  "chat.mcp.autostart": "never",
  "chat.viewProgressBadge.enabled": true
}
