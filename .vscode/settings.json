    "*.env.*": "dotenv",
    "*.ini": "ini",
    "Makefile": "makefile",
    "docker-compose*.yml": "yaml",
    "docker-compose*.yaml": "yaml"
  },
  "makefile.configureOnOpen": false,
  "workbench.tree.indent": 16,
  "cSpell.words": [
    "webpubsub",
    "gigacode",
    "gigachat",
    "pydantic",
    "fastapi",
    "sqlalchemy",
    "langchain",
    "chromadb",
    "pytest",
    "autofetch"
  ]
}
