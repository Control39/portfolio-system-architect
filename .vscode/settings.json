{
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
  "python.terminal.activateEnvironment": true,
  "python.terminal.useEnvFile": true,
  "python.analysis.extraPaths": [
    "${workspaceFolder}/apps",
    "${workspaceFolder}/src"
  ],
  "python.analysis.diagnosticMode": "openFilesOnly",
  "python.analysis.exclude": [
    "**/__pycache__",
    "**/.venv",
    "**/venv",
    "**/.pytest_cache",
    "**/.mypy_cache",
    "**/.ruff_cache",
    "**/.cache",
    "**/node_modules",
    "**/dist",
    "**/build",
    "**/*.egg-info",
    "**/postgres",
    "**/migrations",
    "**/coverage_html",
    "**/reports",
    "**/examples",
    "**/generated_routes",
    "**/.private",
    "**/tests/**",
    "**/apps/*/tests/**"
  ],
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.ignore": [
    "tests/*",
    "apps/*/tests/*"
  ],
  // ================================
  // GigaCode - ПРИОРИТЕТ (основной инструмент)
  // ================================
  "gigacode.enabled": true,
  "gigacode.apiKey": "${env:GIGACODE_API_KEY}",
  "gigacode.model": "GigaChat",
  "gigacode.maxTokens": 4000,
  "gigacode.temperature": 0.7,
  "gigacode.contextWindow": 8000,
  "gigacode.language": "ru",
  "gigacode.enableCodeCompletion": true,
  "gigacode.enableChat": true,
  "gigacode.autoSuggest": true,
  "gigacode.suggestDelay": 500,
  "gigacode.useWorkerForCommands": false,
  "gigacode.experimental.workerEnabled": false,
  "gigacode.inlineCompletions.enabled": true,
  "gigacode.chat.agentModel": "CodeChat",
  "gigacode.chat.askModel": "CodeChat",
  "gigacode.python.enabled": true,
  "gigacode.typescript.enabled": true,
  "gigacode.javascript.enabled": true,
  "gigacode.yaml.enabled": true,
  "gigacode.markdown.enabled": true,
  "gigacode.integrateWithCopilot": false,
  "gigacode.fallbackToSourceCraft": false,
  "gigacode.showTokenUsage": true,
  "gigacode.notifyOnLowTokens": true,
  "gigacode.lowTokenThreshold": 50,
  "gigacode.cache_responses": true,
  // ================================
  // SourceCraft - РЕЖИМ ФОН (только по запросу)
  // ================================
  "sourcecraft-code-assist.account": "leadarchitect@yandex.ru",
  "sourcecraft-code-assist.enableAutoCompletion": false,
  "sourcecraft-code-assist.enableBackgroundAnalysis": false,
  "sourcecraft-code-assist.allowedCommands": [
    "git log",
    "git diff",
    "git show",
    "git status",
    "git branch",
    "git pull",
    "pip list",
    "python --version",
    "pytest --collect-only"
  ],
  "sourcecraft-code-assist.deniedCommands": [
    "rm -rf",
    "sudo",
    "shutdown",
    "reboot",
    "dd",
    "mkfs",
    "chmod 777",
    "git push --force",
    "npm install",
    "pip install"
  ],
  "sourcecraft-code-assist.useWorker": false,
  "sourcecraft-code-assist.runInTerminal": true,
  "sourcecraft-code-assist.autoTrigger": false,
  // ================================
  // Python - линтинг (Ruff)
  // ================================
  "python.linting.ruffEnabled": true,
  "python.linting.ruffArgs": [
    "--fix"
  ],
  // ================================
  // Редактор - глобальные настройки
  // ================================
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.trimAutoWhitespace": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit"
  },
  "editor.rulers": [
    80,
    100,
    120
  ],
  "editor.renderWhitespace": "selection",
  "editor.minimap.enabled": true,
  "workbench.editor.enablePreview": false,
  "explorer.confirmDragAndDrop": false,
  // ================================
  // Python - специфичные настройки
  // ================================
  "[python]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
      "source.fixAll": "explicit"
    }
  },
  // ================================
  // Другие языки
  // ================================
  "[json]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[yaml]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[powershell]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "ms-vscode.powershell"
  },
  "[typescript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[javascript]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[markdown]": {
    "editor.formatOnSave": false
  },
  // ================================
  // Файлы - исключения из проводника
  // ================================
  "files.exclude": {
    "**/.git": true,
    "**/__pycache__": true,
    "**/.venv": true,
    "**/venv": true,
    "**/.pytest_cache": true,
    "**/.cache": true,
    "**/cache": true,
    "**/logs": true,
    "**/*.pyc": true,
    "**/*.pyo": true,
    "**/*.pyd": true,
    "**/.DS_Store": true,
    "**/*.exe": true,
    "**/*.dll": true,
    "**/*.so": true,
    "**/*.local": true
  },
  // ================================
  // Файлы - исключения из наблюдателя
  // ================================
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/.venv/**": true,
    "**/venv/**": true,
    "**/__pycache__/**": true
  },
  // ================================
  // Тестирование - pytest
  // ================================
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": [
    "-p",
    "no:warnings",
    "--tb=short",
    "--cov=.",
    "${workspaceFolder}/tests"
  ],
  // ================================
  // Прочие настройки
  // ================================
  "chat.mcp.autostart": "never",
  "chat.viewProgressBadge.enabled": true,
  "editor.defaultFormatter": "ms-python.black-formatter"
}
