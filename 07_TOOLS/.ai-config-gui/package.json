{
  "name": "ai-config-gui",
  "version": "1.0.0",
  "description": "Графический интерфейс для управления AI-конфигами",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dev": "electron . --debug",
    "test": "jest",
    "test:watch": "jest --watch",
    "monitor": "node scripts/monitor.js",
    "monitor:watch": "nodemon --watch ../.ai-config/master-config.yaml --exec 'node scripts/monitor.js'"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "dotenv": "^17.3.1",
    "electron": "^41.0.0",
    "express": "^4.21.2",
    "fs-extra": "^11.3.4",
    "js-yaml": "^4.1.1",
    "monaco-editor": "^0.53.0",
    "node-fetch": "^3.3.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "electron-builder": "^26.8.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14"
  },
  "build": {
    "appId": "com.portfolio-system-architect.ai-config",
    "productName": "AI Config Manager",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
