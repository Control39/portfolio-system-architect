# AI Config Manager - API Keys
# Copy this file to .env and fill in your keys

# GigaChat (Sber)
GIGACHAT_API_KEY=your_gigachat_api_key_here

# YandexGPT
YANDEXGPT_API_KEY=your_yandexgpt_api_key_here
YANDEXGPT_FOLDER_ID=your_yandex_folder_id_here

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Hugging Face
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Azure
AZURE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_API_KEY=your_azure_api_key_here

# SourceCraft (optional)
SOURCECRAFT_TOKEN=your_sourcecraft_token_here

