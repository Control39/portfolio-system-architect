[run]
branch = True
source =
    apps/
    src/
    tools/
omit =
    */tests/*
    */__pycache__/*
    */migrations/*
    */venv/*
    */.venv/*
    */node_modules/*
    */build/*
    */dist/*
    */.eggs/*
    */htmlcov/*
    */coverage_html/*
    */db.py
    */db_sync.py
    */main.py
    */core/competency_tracker.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    @property
    @abstractmethod
    @staticmethod
    @classmethod

[html]
directory = coverage_html
title = Portfolio System Architect Test Coverage

[paths]
source =
    apps/
    src/
    tools/

[coverage:run]
data_file = .coverage
parallel = True

[coverage:report]
precision = 2
show_missing = True
skip_covered = False
fail_under = 80
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if settings.DEBUG
    raise AssertionError
    raise NotImplementedError


# Добавлено из .coveragerc.cd
[run]
source =
    apps/career_development
omit =
    */__pycache__/*
    */db_sync.py
    */main.py
    */core/__init__.py
    */api/*
    */config/*
    */src/tests/*

[report]
fail_under = 80
precision = 2
show_missing = true
