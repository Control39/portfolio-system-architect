# ============================================
# .gitignore - Clean and organized
# ============================================

# === Python ===
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
.eggs/
dist/
build/
*.so
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# === Testing ===
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.hypothesis/

# === IDE ===
.vscode/
.idea/
*.swp
*.swo
*~

# === OS ===
.DS_Store
Thumbs.db

# === Logs ===
*.log
logs/

# === Environment ===
.env
.env.*
!.env.example
!.env.test

# === Node.js ===
node_modules/

# === Agent runtime data ===
.agent_data/
.agent_state/
.agents/
.agents.disabled/
chroma_db/

# === Reports and artifacts ===
reports/
*.scan.json

# === Temporary files ===
*.tmp
*.temp
*.bak
*.backup

# === Archives ===
*.zip
*.tar.gz

# === Secrets ===
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
authorized_keys
id_rsa
id_ed25519

# === Build artifacts ===
*.egg-info/
*.whl
wheels/

# === Cache ===
.cache/
.ruff_cache/
.mypy_cache/

# === Legacy (if needed) ===
legacy/
archive/

# ============================================
# End of .gitignore
# ============================================

