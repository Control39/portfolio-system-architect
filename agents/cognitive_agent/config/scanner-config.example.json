{
  "timeout": 30,
  "max_workers": 4,
  "max_file_size": 104857600,
  "include_extensions": [
    ".py",
    ".js",
    ".ts",
    ".jsx",
    ".tsx",
    ".json",
    ".yml",
    ".yaml",
    ".md",
    ".txt",
    ".html",
    ".css",
    ".sql"
  ],
  "extra_ignores": [
    "node_modules",
    ".venv",
    ".venv_local",
    "__pycache__",
    ".git",
    ".idea",
    ".vscode",
    "*.egg-info",
    "dist",
    "build",
    ".pytest_cache",
    ".mypy_cache",
    ".ruff_cache"
  ],
  "cache_file": ".cognitive_agent_scan_cache.json"
}
