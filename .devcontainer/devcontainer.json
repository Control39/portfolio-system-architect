{
    "name": "Arch-Compass Development",
    "image": "mcr.microsoft.com/powershell:latest",
    "features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/python:3": {
            "version": "3.12"
        }
    },
    "postCreateCommand": "pip install mkdocs-material",
    "customizations": {
