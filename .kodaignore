# ==========================================
# KODA CLI Ignore Configuration
# ==========================================
# Этот файл контролирует, какие файлы и папки Koda CLI должен игнорировать
# По умолчанию Koda видит ВСЁ, кроме указанных здесь паттернов

# ==========================================
# КЭШИ И ВРЕМЕННЫЕ ФАЙЛЫ (безопасно игнорировать)
# ==========================================
**/__pycache__/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.node_gyp/
**/node_modules/
**/dist/
**/build/
**/*.egg-info/

# ==========================================
# ЛОГИ И ВРЕМЕННЫЕ ДАННЫЕ
# ==========================================
**/*.log
**/logs/
agents/logs/
.cache/
tmp/
temp/
.tmp/

# ==========================================
# ГЕНЕРИРУЕМЫЕ ОТЧЁТЫ И АНАЛИТИКА
# ==========================================
*-REPORT.md
*-ANALYSIS.md
*-SUMMARY.md
IMPROVEMENTS-TODO.md
TODO*.md
*-report.json
*-analysis-report.txt
health-report.json
project_health_report.json

# ==========================================
# ГЕНЕРИРУЕМЫЕ ФАЙЛЫ И САЙТЫ
# ==========================================
docs/_build/
docs/mkdocs-site/
docs/obsidian-map/
.obsidian/
**/obsidian-vault/
**/obsidian-map/
*.db
/site/
htmlcov/
.coverage*

# ==========================================
# СЕКРЕТЫ И КРЕДЕНЦИАЛИ (безопасность)
# ==========================================
.env
.env.*
*.key
*.pem
*.p12
*.pfx
kubeconfig
*credentials*.json
secrets/sealed-secrets/*.yaml
!.secrets.baseline

# ==========================================
# ПЕРСОНАЛЬНЫЕ ИНСТРУМЕНТЫ
# ==========================================
personal-tools/
10_BACKUPS/
manual-review/

# ==========================================
# ВРЕМЕННЫЕ ФАЙЛЫ РЕДАКТОРОВ
# ==========================================
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini
*.gitconfig

# ==========================================
# КОПИИ И РЕЗЕРВЫ
# ==========================================
README.md.backup
tools/.ai-config-gui-backup-*/
trivy.zip
*.tmp

# ==========================================
# AI CONFIG (локальные конфиги агентов)
# ==========================================
agents/local/config/*.local.yaml
agents/gigacode/config/*.local.yaml
.ai-config/

# ==========================================
# ALLOWED (явно разрешаем для Koda)
# ==========================================
# Эти файлы ДОЛЖНЫ быть видны, даже если они в игнорируемых папках:
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.codeassistant/context.md
!.codeassistant/mcp.json
!.codeassistant/ai-models.yaml
!.agents/README.md
!.agents/config/
!.agents/skills/
!.agents/workflows/
