# Конфигурация окружения для Template Service
# Скопируйте этот файл в .env и настройте значения

# Основные настройки приложения
APP_NAME="Template Service"
APP_VERSION="0.1.0"
ENVIRONMENT="development"  # development, staging, production
DEBUG=true
LOG_LEVEL="INFO"

# Настройки сервера
HOST="0.0.0.0"
PORT=8000

# Настройки CORS (через запятую)
CORS_ORIGINS="http://localhost:3000,http://localhost:8000"

# Настройки базы данных
DATABASE_URL="postgresql://user:password@localhost:5432/template_db"
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Настройки Redis
REDIS_URL="redis://localhost:6379/0"
REDIS_POOL_SIZE=10

# Настройки внешних API
EXTERNAL_API_BASE_URL="https://api.example.com"
EXTERNAL_API_TIMEOUT=30

# Настройки безопасности
SECRET_KEY="change-this-in-production"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=60

# Настройки мониторинга
SENTRY_DSN=""  # Опционально: для Sentry
PROMETHEUS_METRICS_ENABLED=true
