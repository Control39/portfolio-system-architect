{
  "files.encoding": "utf8",
  "files.autoGuessEncoding": false,
  "files.detectEncoding": "auto",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,

  "[python]": {
    "files.encoding": "utf8",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },

  "[javascript]": {
    "files.encoding": "utf8",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },

  "[typescript]": {
    "files.encoding": "utf8",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },

  "[html]": {
    "files.encoding": "utf8",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },

  "[css]": {
    "files.encoding": "utf8",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },

  "[json]": {
    "files.encoding": "utf8",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },

  "[markdown]": {
    "files.encoding": "utf8",
    "editor.wordWrap": "on",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },

  "problems.decorations.enabled": true,
  "files.saveEncoding": "utf8",
  "editor.renderControlCharacters": true,
  "editor.renderWhitespace": "boundary",
  "security.workspace.trust.untrustedFiles": "open"
}
