{
  "//": "Настройки VS Code для работы с UTF-8 кодировкой",
  "//": "Этот файл нужно поместить в .vscode/settings.json проекта",

  "files.encoding": "utf8",
  "files.autoGuessEncoding": false,
  "files.detectEncoding": "auto",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,

  "[python]": {
    "files.encoding": "utf8",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },

  "[javascript]": {
    "files.encoding": "utf8",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },

  "[typescript]": {
    "files.encoding": "utf8",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },

  "[html]": {
    "files.encoding": "utf8",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },

  "[css]": {
    "files.encoding": "utf8",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },

  "[json]": {
    "files.encoding": "utf8",
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },

  "[markdown]": {
    "files.encoding": "utf8",
    "editor.wordWrap": "on",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false
  },

  "//": "Подсветка проблем с кодировкой",
  "problems.decorations.enabled": true,

  "//": "Предотвращение случайного сохранения в неправильной кодировке",
  "files.saveEncoding": "utf8",

  "//": "Отображение невидимых символов для отладки проблем с кодировкой",
  "editor.renderControlCharacters": true,
  "editor.renderWhitespace": "boundary",

  "//": "Проверка конфигурации при открытии проекта",
  "security.workspace.trust.untrustedFiles": "open"
}
