[[source]]
url = "https://pypi.org/simple"
verify_ssl = true
name = "pypi"

[packages]
pyyaml = ">=6.0"
requests = ">=2.31.0"
python-dotenv = ">=1.0.0"
pydantic = ">=2.0.0"
pydantic-settings = ">=2.0.0"
typer = ">=0.9.0"
rich = ">=13.0.0"
tqdm = ">=4.65.0"
schedule = ">=1.2.0"

[dev-packages]
pytest = ">=7.4.0"
pytest-cov = ">=4.1.0"
pytest-asyncio = ">=0.23.0"
ruff = ">=0.1.0"
mypy = ">=1.8.0"
black = ">=24.0.0"
bandit = ">=1.7.0"
detect-secrets = ">=1.5.0"

[requires]
python_version = "3.12"

[scripts]
test = "pytest apps/*/tests/ -v"
test-cov = "pytest apps/*/tests/ --cov=apps --cov-report=term-missing"
lint = "ruff check ."
format = "black . && ruff format ."
mypy = "mypy ."
