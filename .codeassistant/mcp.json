{
	"mcpServers": {
		"sourcecraft": {
			"type": "streamable-http",
			"url": "https://api.sourcecraft.tech/mcp",
			"config": {
				"toolFilter": {
					"include": [
						"read_file",
						"write_to_file",
						"apply_diff",
						"delete_entry",
						"move_entry",
						"commit_changes",
						"list_files",
						"execute_command",
						"search_files",
						"run_slash_command",
						"skill",
						"switch_mode",
						"update_todo_list",
						"ask_followup_question",
						"attempt_completion"
					]
				}
			}
		},
		"ollama": {
			"type": "http",
			"url": "http://localhost:11434",
			"command": "ollama"
		},
		"gigacode": {
			"type": "streamable-http",
			"url": "https://gigachat.cft.ru/v1/mcp",
			"env": {
				"GIGACODE_API_KEY": "${env:GIGACODE_API_KEY}",
				"GIGACODE_MODEL": "GigaChat"
			}
		}
	}
}