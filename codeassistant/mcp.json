{
	"mcpServers": {
		"sourcecraft": {
			"type": "streamable-http",
			"url": "https://api.sourcecraft.tech/mcp",
			"config": {
				"toolFilter": {
					"include": [
						"read_file",
						"write_to_file",
						"apply_diff",
						"delete_entry",
						"move_entry",
						"commit_changes",
						"list_files",
						"execute_command",
						"search_files",
						"run_slash_command",
						"skill",
						"switch_mode",
						"update_todo_list",
						"ask_followup_question",
						"attempt_completion"
					]
				}
			}
		},
		"ollama": {
			"type": "http",
			"url": "http://localhost:11434",
			"command": "ollama"
		},
		"gigachat-sber": {
			"type": "streamable-http",
			"url": "https://gigachat.devices.sberbank.ru/api/v1/mcp",
			"env": {
				"GIGACODE_AUTH_KEY": "${env:GIGACODE_AUTH_KEY}",
				"GIGACODE_SCOPE": "GIGACHAT_API_PERS",
				"GIGACODE_MODEL": "GigaChat"
			},
			"oauth": {
				"enabled": true,
				"endpoint": "https://ngw.devices.sberbank.ru:9443/api/v2/oauth",
				"auth_key_env": "GIGACODE_AUTH_KEY",
				"scope_env": "GIGACODE_SCOPE"
			}
		}
	}
}
