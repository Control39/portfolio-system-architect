# Environment variables for Portfolio System Architect
# ===================================================
# Copy this file to .env and fill in REAL values for production.
# NEVER commit .env with actual secrets to version control!
#
# For testing: use test-specific values or leave as placeholders.

# =============================================================================
# Authentication (Required by: auth_service, chat_backend)
# =============================================================================
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_A_SECURE_KEY

# =============================================================================
# Database (Required by: auth_service, chat_backend, and others)
# =============================================================================
# PostgreSQL (production)
DATABASE_URL=postgresql://username:password@localhost:5432/portfolio_db

# SQLite (testing/development only)
# DATABASE_URL=sqlite:///./test.db

# =============================================================================
# PostgreSQL credentials (for docker-compose)
# =============================================================================
POSTGRES_DB=portfolio_db
POSTGRES_USER=portfolio_user
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# =============================================================================
# Optional: AI Provider Keys
# =============================================================================
# OPENAI_API_KEY=sk-...
# GIGACHAT_CLIENT_ID=...
# GIGACHAT_CLIENT_SECRET=...

# =============================================================================
# Optional: Infrastructure
# =============================================================================
# REDIS_URL=redis://localhost:6379/0
# JAEGER_ENDPOINT=http://localhost:14268/api/traces

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
