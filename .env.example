# ============================================================
# Environment Configuration - COPY TO .env FOR LOCAL DEVELOPMENT
# DO NOT COMMIT ACTUAL SECRETS - USE .env.local (gitignored)
# ============================================================

# Database
POSTGRES_DB=portfolio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_in_local_env
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Application
PYTHONPATH=/app
ENVIRONMENT=development

# ML Model Registry
ML_MODELS_PATH=/app/models
ML_DATABASE_URL=${DATABASE_URL}

# Cloud Reason (RAG)
CLOUD_REASON_PORT=8001
RAG_INDEX_PATH=/app/data/rag-index

# IT Compass
IT_COMPASS_PORT=8501
IT_DATA_PATH=/app/data

# Career Development
CAREER_DEV_PORT=8000

# Portfolio Organizer
PORTFOLIO_ORGANIZER_PORT=8004

# System Proof
SYSTEM_PROOF_PORT=8003
PROOF_STORAGE_PATH=/app/data/proofs

# Logging
LOG_LEVEL=INFO
LOG_PATH=/app/logs

# Security
JWT_SECRET=changeme_in_local_env
JWT_ALGORITHM=HS256
API_KEY_SECRET=changeme_in_local_env

# Optional: Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=admin

# Optional: Cloud credentials (for GCP/AWS deployment)
# GCP_PROJECT_ID=your-project-id
# GCP_CREDENTIALS_JSON=path/to/credentials.json
# AWS_REGION=us-east-1
