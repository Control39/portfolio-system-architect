# =============================================================================
# ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ - ШАБЛОН
# =============================================================================
# Скопируйте этот файл в .env и заполните значениями
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# GigaCode API
# -----------------------------------------------------------------------------
GIGACODE_API_KEY=your_api_key_here
GIGACODE_MODEL=GigaChat
GIGACODE_BASE_URL=https://gigachat.cft.ru/v1

# -----------------------------------------------------------------------------
# SourceCraft
# -----------------------------------------------------------------------------
SOURCECRAFT_API_KEY=your_sourcecraft_key_here
SOURCECRAFT_MCP_URL=https://api.sourcecraft.tech/mcp

# -----------------------------------------------------------------------------
# База данных (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=portfolio_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
DOCKER_REGISTRY=localhost:5000
DOCKER_NETWORK=portfolio-network

# -----------------------------------------------------------------------------
# Микросервисы
# -----------------------------------------------------------------------------
AUTH_SERVICE_PORT=8001
API_GATEWAY_PORT=8000
CAREER_SERVICE_PORT=8002
DECISION_ENGINE_PORT=8003
KNOWLEDGE_GRAPH_PORT=8004
ML_REGISTRY_PORT=8005
MONITORING_PORT=9090

# -----------------------------------------------------------------------------
# Redis (кэш и очереди)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# -----------------------------------------------------------------------------
# Prometheus & Grafana
# -----------------------------------------------------------------------------
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000
GRAFANA_ADMIN_PASSWORD=your_grafana_admin_password

# -----------------------------------------------------------------------------
# Безопасность
# -----------------------------------------------------------------------------
SECRET_KEY=your_django_secret_key_here_min_50_chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ENCRYPTION_KEY=your_32_char_encryption_key_here

# -----------------------------------------------------------------------------
# Логирование
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log

# -----------------------------------------------------------------------------
# Разработка
# -----------------------------------------------------------------------------
DEBUG=True
ENVIRONMENT=development
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Внешние API
# -----------------------------------------------------------------------------
HH_API_KEY=your_headhunter_api_key
GITHUB_TOKEN=your_github_token
GITLAB_TOKEN=your_gitlab_token

# -----------------------------------------------------------------------------
# Векторная база данных (ChromaDB / Qdrant)
# -----------------------------------------------------------------------------
CHROMA_DB_PATH=./data/chroma
QDRANT_URL=http://localhost:6333
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
