# Порт, на котором будет запущен MCP-сервер
MCP_SERVER_PORT=8000

# Базовый URL для API GIGA IDE (если используется)
GIGA_IDE_API_URL=https://gigacode.ru/api/v2

# Токен для доступа к API (временно пустой, нужно будет заполнить)
API_TOKEN=

# Режим разработки
DEBUG=True

# Секретный ключ для приложения (для Flask/Django)
SECRET_KEY=your-secret-key-here-change-in-production

# URL для базы данных (если используется)
DATABASE_URL=sqlite:///./app.db

# URL для Redis (если используется для очередей)
REDIS_URL=redis://localhost:6379/0

# GIGA_PROJECT_ID
54b03e66-d6b4-4945-aae4-e071d1439347

# GIGA_API_KEY
GIGACODE_API_KEY=your-api-key-here-change-in-production
