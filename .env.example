# ==========================================
# Environment Variables Configuration Template
# ==========================================
# Скопируйте этот файл в .env и заполните значениями
# НЕ КОМИТЬТЕ .env в git!
# ==========================================

# ==========================================
# AI & LLM API Keys
# ==========================================

# GigaChat (Сбер) - GigaCode интеграция
GIGACODE_API_KEY=<YOUR_GIGACODE_API_KEY>
GIGACODE_BASE_URL=https://gigachat.cloud.sberbank.ru

# OpenAI (если используется)
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# Anthropic Claude
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>

# Yandex GPT
YANDEX_GPT_API_KEY=<YOUR_YANDEX_GPT_API_KEY>

# ==========================================
# Database Configuration
# ==========================================

# PostgreSQL
DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@localhost:5432/portfolio_system
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=portfolio_system
DATABASE_USER=postgres
DATABASE_PASSWORD=<DB_PASSWORD>

# Redis (кэширование и очереди)
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<REDIS_PASSWORD>

# ==========================================
# Authentication & Security
# ==========================================

# JWT Secret Key
JWT_SECRET_KEY=<GENERATE_RANDOM_SECRET>

# OAuth Providers
GOOGLE_CLIENT_ID=<YOUR_GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<YOUR_GOOGLE_CLIENT_SECRET>
GITHUB_CLIENT_ID=<YOUR_GITHUB_CLIENT_ID>
GITHUB_CLIENT_SECRET=<YOUR_GITHUB_CLIENT_SECRET>

# ==========================================
# API Configuration
# ==========================================

# FastAPI Settings
APP_TITLE=Portfolio System Architect
APP_VERSION=1.0.0
DEBUG=true

# API Rate Limiting
RATELIMIT_ENABLED=true
RATELIMIT_STRING=100 per minute

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# ==========================================
# Service URLs
# ==========================================

# Decision Engine
DECISION_ENGINE_URL=http://localhost:8001

# IT Compass UI
IT_COMPASS_URL=http://localhost:8501

# Infrastructure Orchestrator
INFRA_ORCHESTRATOR_URL=http://localhost:8002

# Portfolio Organizer
PORTFOLIO_ORGANIZER_URL=http://localhost:8003

# ==========================================
# Monitoring & Observability
# ==========================================

# Prometheus
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_SCRAPE_INTERVAL=30s

# Grafana
GRAFANA_URL=http://localhost:3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<GRAFANA_PASSWORD>

# Sentry (опционально)
SENTRY_DSN=<YOUR_SENTRY_DSN>
SENTRY_ENVIRONMENT=development

# ==========================================
# Logging
# ==========================================

LOG_LEVEL=DEBUG
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ==========================================
# Vector Database (ChromaDB)
# ==========================================

CHROMADB_PERSIST_DIRECTORY=./data/chromadb
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# ==========================================
# Docker & Kubernetes
# ==========================================

DOCKER_HOST=tcp://localhost:2375
KUBE_CONFIG_PATH=~/.kube/config

# ==========================================
# CI/CD & Git Integration
# ==========================================

GITHUB_TOKEN=<YOUR_GITHUB_TOKEN>
GITLAB_TOKEN=<YOUR_GITLAB_TOKEN>
SOURCECRAFT_API_TOKEN=<YOUR_SOURCECRAFT_TOKEN>

# ==========================================
# Notification Services
# ==========================================

# Slack
SLACK_WEBHOOK_URL=<YOUR_SLACK_WEBHOOK>
SLACK_BOT_TOKEN=<YOUR_SLACK_BOT_TOKEN>

# Telegram
TELEGRAM_BOT_TOKEN=<YOUR_TELEGRAM_BOT_TOKEN>
TELEGRAM_CHAT_ID=<YOUR_TELEGRAM_CHAT_ID>

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<YOUR_EMAIL>
SMTP_PASSWORD=<YOUR_EMAIL_PASSWORD>
EMAIL_FROM=<YOUR_EMAIL>

# ==========================================
# Storage (S3/MinIO)
# ==========================================

S3_ENDPOINT_URL=<YOUR_S3_ENDPOINT>
S3_ACCESS_KEY_ID=<YOUR_S3_ACCESS_KEY>
S3_SECRET_ACCESS_KEY=<YOUR_S3_SECRET_KEY>
S3_BUCKET_NAME=<YOUR_S3_BUCKET>

# MinIO (локальное хранилище)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ==========================================
# Feature Flags
# ==========================================

ENABLE_RAG=true
ENABLE_AI_ASSISTANT=true
ENABLE_AUTO_AUDIT=true
ENABLE_TELEMETRY=false

# ==========================================
# Development Settings
# ==========================================

RELOAD_ENABLED=true
WORKERS_COUNT=1
ASYNC_WORKERS=4

# ==========================================
# Cache Configuration
# ==========================================

CACHE_TTL_DEFAULT=3600
CACHE_TTL_LONG=86400

# ==========================================
# Timeouts
# ==========================================

API_TIMEOUT=30
DATABASE_TIMEOUT=10
REDIS_TIMEOUT=5
