# Шаблон переменных окружения для Portfolio System Architect
# Скопируйте этот файл в .env и заполните значения
# pragma: allowlist secret

# ====================
# БАЗОВЫЕ НАСТРОЙКИ
# ====================
APP_NAME=portfolio-system-architect
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key-$(openssl rand -hex 32)

# ====================
# БАЗЫ ДАННЫХ
# ====================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=portfolio_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here  # pragma: allowlist secret

DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/portfolio_db  # pragma: allowlist secret

# ====================
# REDIS
# ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ====================
# AI API КЛЮЧИ
# ====================
# Ollama (локальная модель)
OLLAMA_HOST=http://localhost:11434

# YandexGPT
YANDEXGPT_API_KEY=your_yandexgpt_api_key
YANDEXGPT_FOLDER_ID=your_folder_id

# GigaChat
GIGACHAT_API_KEY=your_gigachat_api_key
GIGACODE_AUTH_KEY=your_gigacode_auth_key

# OpenAI (если используется)
OPENAI_API_KEY=sk-your_openai_api_key

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key

# ====================
# ВЕКТОРНЫЕ БАЗЫ ДАННЫХ
# ====================
# ChromaDB (локальная, не требует ключа)
CHROMA_DB_PATH=./data/chroma_db

# Pinecone (опционально)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENV=your_pinecone_environment

# ====================
# JWT AUTHENTICATION
# ====================
JWT_SECRET=change-this-jwt-secret-key-$(openssl rand -hex 32)
JWT_EXPIRE_MINUTES=1440  # 24 часа

# ====================
# ТЕЛЕГРАМ УВЕДОМЛЕНИЯ
# ====================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ====================
# EMAIL (SMTP)
# ====================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

ALERT_EMAIL=alerts@example.com

# ====================
# GITHUB / GITLAB
# ====================
GITHUB_TOKEN=your_github_token
GITLAB_TOKEN=your_gitlab_token

# ====================
# МОНИТОРИНГ
# ====================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Sentry (опционально)
SENTRY_DSN=https://your_sentry_dsn

# ====================
# SOURCECRAFT
# ====================
SOURCECRAFT_API_KEY=your_sourcecraft_api_key

# ====================
# НАСТРОЙКИ ПРИЛОЖЕНИЯ
# ====================
RATE_LIMIT_REQUESTS=100
MAX_UPLOAD_SIZE=10485760  # 10MB
LOG_LEVEL=INFO
LOG_DIR=./logs

# ====================
# БЕЗОПАСНОСТЬ
# ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8501

# ====================
# РАЗРАБОТКА
# ====================
SKIP_AUTH=false
USE_LOCAL_DB=true
ENABLE_MOCKS=true

# ====================
# КОГНИТИВНЫЙ АГЕНТ
# ====================
CAA_ENABLED=true
CAA_AUDIT_INTERVAL_HOURS=24
CAA_MAX_CONCURRENT_AUDITS=2

# ====================
# IT-COMPASS
# ====================
IT_COMPASS_MARKERS_FILE=./apps/it-compass/data/system_thinking.json
IT_COMPASS_REPORTS_DIR=./docs/reports/it-compass

# ====================
# ML MODEL REGISTRY
# ====================
MLFLOW_TRACKING_URI=http://localhost:5000
ML_MODEL_REGISTRY_PATH=./data/models

# ====================
# ИНСТРУМЕНТЫ
# ====================
# Trivy (безопасность)
TRIVY_SKIP_UPDATE=true

# Bandit (Python безопасность)
BANDIT_OUTPUT_FORMAT=sarif

# ====================
# ПРИМЕРЫ ИСПОЛЬЗОВАНИЯ
# ====================
# 1. Скопируйте этот файл: cp .env.example .env
# 2. Заполните обязательные поля (помечены 'your_')
# 3. Никогда не коммитьте .env файл в Git
# 4. Для production используйте секреты в Kubernetes/докере
# 5. Генерация секретных ключей:
#    - openssl rand -hex 32 (для SECRET_KEY, JWT_SECRET)
#    - python -c "import secrets; print(secrets.token_urlsafe(32))"
