#!/usr/bin/env python
"""
Pre-commit hook для проверки структуры сервисов.

Запускается автоматически перед каждым коммитом.
Если проверка не пройдена — коммит блокируется.

Установка:
    chmod +x .hooks/pre-commit-service-structure
    ln -s ../../.hooks/pre-commit-service-structure .git/hooks/pre-commit
"""

import subprocess
import sys
from pathlib import Path


def run_check():
    """Запустить проверку структуры сервисов."""
    print("\n" + "=" * 80)
    print("Pre-commit check: Проверка структуры сервисов")
    print("=" * 80 + "\n")
    
    script_path = Path(__file__).parent.parent / "scripts" / "check_service_structure.py"
    
    if not script_path.exists():
        print("❌ Скрипт проверки не найден:", script_path)
        return False
    
    result = subprocess.run(
        [sys.executable, str(script_path)],
        capture_output=False,
        text=True
    )
    
    if result.returncode != 0:
        print("\n" + "=" * 80)
        print("❌ Pre-commit check FAILED")
        print("Исправьте проблемы перед коммитом:")
        print("  python scripts/auto_fix_service_structure.py --all")
        print("=" * 80 + "\n")
        return False
    
    print("\n" + "=" * 80)
    print("✅ Pre-commit check PASSED")
    print("=" * 80 + "\n")
    return True


if __name__ == "__main__":
    success = run_check()
    sys.exit(0 if success else 1)